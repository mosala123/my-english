  const generateFeedback = () => {
    const duration = recordingTime
    const targetTime = currentExercise.targetTime
    
    let timeFeedback = ''
    let timeScore = 0
    
    if (duration < targetTime * 0.5) {
      timeFeedback = 'Your response was quite short. Try to provide more details and examples.'
      timeScore = 6
    } else if (duration < targetTime * 0.8) {
      timeFeedback = 'Good length, but you could elaborate more on some points.'
      timeScore = 7.5
    } else if (duration <= targetTime * 1.2) {
      timeFeedback = 'Excellent! Your response had an appropriate length.'
      timeScore = 9
    } else {
      timeFeedback = 'Your response was a bit long. Try to be more concise.'
      timeScore = 7
    }

    const fluencyScore = Math.floor(Math.random() * 3) + 7
    const pronunciationScore = Math.floor(Math.random() * 3) + 7
    const vocabularyScore = Math.floor(Math.random() * 3) + 7
    const grammarScore = Math.floor(Math.random() * 3) + 7
    
    const overallScore = ((timeScore + fluencyScore + pronunciationScore + vocabularyScore + grammarScore) / 5).toFixed(1)

    const feedbackObj = {
      overall: parseFloat(overallScore),
      time: timeFeedback,
      scores: {
        fluency: fluencyScore,
        pronunciation: pronunciationScore,
        vocabulary: vocabularyScore,
        grammar: grammarScore,
        timing: timeScore
