                            <IoCheckmarkCircle className="w-6 h-6 text-green-600" />
                            AI Feedback
                          </h3>
                      
                          {/* Overall Score */}
                          <div className="text-center mb-6">
                            <div className="inline-flex flex-col items-center">
                              <span className="text-4xl font-bold text-gray-900 mb-1">
                                {feedback.overall}/10
                              </span>
                              <span className="text-lg font-semibold text-gray-700">Overall Score</span>
                              <div className="w-32 h-2 bg-gray-200 rounded-full mt-2 overflow-hidden">
                                <div 
                                  className="h-full bg-gradient-to-r from-green-500 to-blue-500 transition-all duration-1000"
                                  style={{ width: `${feedback.overall * 10}%` }}
                                ></div>
                              </div>
                            </div>
                          </div>
                      
                          {/* Detailed Scores */}
                          <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 mb-6">
                            {Object.entries(feedback.scores).map(([key, score]) => (
                              <div key={key} className="text-center bg-white rounded-lg p-3 shadow-sm">
                                <div className="text-2xl font-bold text-gray-900 mb-1">{score}/10</div>
                                <div className="text-xs font-medium text-gray-600 uppercase tracking-wide">
                                  {key}
                                </div>
                                <div className="w-full h-1 bg-gray-200 rounded-full mt-2 overflow-hidden">
                                  <div 
                                    className="h-full bg-blue-500 transition-all duration-1000"
                                    style={{ width: `${score * 10}%` }}
                                  ></div>
                                </div>
                              </div>
                            ))}
                          </div>
                      
                          {/* Time Feedback */}
                          <div className="mb-4 p-3 bg-blue-50 rounded-lg">
                            <h4 className="font-semibold text-gray-900 mb-1">⏱️ Timing Feedback:</h4>
                            <p className="text-gray-700 text-sm">{feedback.time}</p>
                          </div>
                      
                          {/* Strengths & Improvements */}
                          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div className="bg-white rounded-lg p-4 border-2 border-green-200">
                              <h4 className="font-semibold text-green-800 mb-2 flex items-center gap-2">
                                <IoCheckmarkCircle className="w-4 h-4" />
                                Your Strengths
                              </h4>
                              <ul className="space-y-1">
                                {feedback.strengths.map((strength, index) => (
                                  <li key={index} className="text-sm text-gray-700 flex items-start gap-2">
                                    <span className="text-green-500 mt-0.5">•</span>
                                    {strength}
                                  </li>
                                ))}
                              </ul>
                            </div>
                      
                            <div className="bg-white rounded-lg p-4 border-2 border-orange-200">
                              <h4 className="font-semibold text-orange-800 mb-2 flex items-center gap-2">
                                <IoRefresh className="w-4 h-4" />
                                Areas to Improve
                              </h4>
                              <ul className="space-y-1">
                                {feedback.improvements.map((improvement, index) => (
                                  <li key={index} className="text-sm text-gray-700 flex items-start gap-2">
                                    <span className="text-orange-500 mt-0.5">•</span>
                                    {improvement}
                                  </li>
                                ))}
                              </ul>
                            </div>
                          </div>
                      
                          {/* Suggestions */}
                          <div className="mt-4 bg-white rounded-lg p-4 border-2 border-purple-200">
                            <h4 className="font-semibold text-purple-800 mb-2 flex items-center gap-2">
                              <IoBookmark className="w-4 h-4" />
                              Practice Suggestions
                            </h4>
                            <ul className="space-y-2">
                              {feedback.suggestions.map((suggestion, index) => (
                                <li key={index} className="text-sm text-gray-700 flex items-start gap-2">
                                  <span className="text-purple-500 mt-0.5">•</span>
                                  {suggestion}
                                </li>
                              ))}
                            </ul>
                          </div>
                      
                          {/* Sample Response */}
                          <div className="mt-4 bg-gradient-to-r from-purple-50 to-pink-50 rounded-lg p-4 border-2 border-purple-200">
                            <h4 className="font-semibold text-purple-800 mb-2 flex items-center gap-2">
                              <IoStar className="w-4 h-4" />
                              Sample Response
                            </h4>
                            <p className="text-sm text-gray-700 leading-relaxed">
                              {currentExercise.sampleResponse}
                            </p>
                          </div>
                        </div>
                      )}
                      
                      {/* Navigation */}
                      <div className="flex justify-between items-center mt-6 pt-4 border-t border-gray-200">
                        <button
                          onClick={() => {
                            if (selectedExercise > 0) {
                              setSelectedExercise(selectedExercise - 1)
                              setShowFeedback(false)
                              setRecordedAudio(null)
                              setRecordingTime(0)
                            }
                          }}
                          disabled={selectedExercise === 0}
                          className="flex items-center gap-2 px-4 py-2 rounded-lg border-2 border-gray-300 text-gray-700 hover:bg-gray-50 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                        >
                          <IoArrowForward className="w-4 h-4 rotate-180" />
                          Previous
                        </button>
                      
                        <div className="flex items-center gap-2 text-sm text-gray-600">
                          <span className="font-medium">Exercise {selectedExercise + 1} of {speakingExercises.length}</span>
                        </div>
                      
                        <button
                          onClick={() => {
                            if (selectedExercise < speakingExercises.length - 1) {
                              setSelectedExercise(selectedExercise + 1)
                              setShowFeedback(false)
                              setRecordedAudio(null)
                              setRecordingTime(0)
                            }
                          }}
                          disabled={selectedExercise === speakingExercises.length - 1}
                          className="flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                        >
                          Next
                          <IoArrowForward className="w-4 h-4" />
                        </button>
                      </div>
                      </div>
                      
                      {/* Progress Stats */}
                      <div className="bg-white rounded-xl shadow-lg p-6 mt-6">
                        <h3 className="text-lg font-bold text-gray-900 mb-4">Your Progress</h3>
                        <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
                          <div className="text-center">
                            <div className="text-2xl font-bold text-blue-600">{completedExercises.length}</div>
                            <div className="text-sm text-gray-600">Completed</div>
                          </div>
                          <div className="text-center">
                            <div className="text-2xl font-bold text-green-600">
                              {Math.round((completedExercises.length / speakingExercises.length) * 100)}%
                            </div>
                            <div className="text-sm text-gray-600">Overall Progress</div>
                          </div>
                          <div className="text-center">
                            <div className="text-2xl font-bold text-purple-600">
                              {Math.max(...completedExercises.map(id => speakingExercises.find(e => e.id === id)?.targetTime || 0))}s
                            </div>
                            <div className="text-sm text-gray-600">Longest Recording</div>
                          </div>
                          <div className="text-center">
                            <div className="text-2xl font-bold text-orange-600">
                              {categories.find(cat => cat.id === selectedCategory)?.name}
                            </div>
                            <div className="text-sm text-gray-600">Current Category</div>
                          </div>
                        </div>
                      </div>
                      </div>
                      </div>
                      </div>
                        )
                      }
                      
                      export default SpeakingPage